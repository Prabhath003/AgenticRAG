# AgenticRAG Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URL=mongodb://localhost:27017/agentic-rag

# For MongoDB Atlas:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/agentic-rag?retryWrites=true&w=majority

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# AWS Region for Bedrock
AWS_BEDROCK_REGION=us-east-1

# S3 Configuration
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ALIAS=optional-bucket-alias

# RDS Configuration (for operation logging)
AWS_RDS_HOST_URL=your-rds-endpoint.rds.amazonaws.com
AWS_RDS_PORT=3306
AWS_RDS_USER=admin
AWS_RDS_PASSWORD=your-rds-password
AWS_RDS_CHARSET=utf8mb4

# =============================================================================
# LLM Configuration
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Azure OpenAI Configuration (optional)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key

# =============================================================================
# Optional Configuration
# =============================================================================

# Load additional config from JSON file
# CONFIG_PATH=config.json